# ============================================================
# Docker Compose Stack — Hosts & Ports (matches docker-compose.yml)
# All services bind to 127.0.0.1 on host unless noted.
# ============================================================
# L1 Execution (reth)        HTTP RPC: 8545, WS: 8546, Engine: 8551, Metrics: 9001, P2P: 30303/tcp+udp, discv5: 9200/udp
# L1 Consensus (lighthouse)  Beacon API: 5052, Metrics: 8008, P2P: 9000/tcp+udp, QUIC: 9001/udp
# L2 Execution (base-reth)   HTTP RPC: 8547, WS: 8548, Engine: 8552, Metrics: 9002, P2P: 30305/tcp+udp, discv5: 9201/udp
# Rollup client (op-node)     RPC/sync: 7545, Metrics: 7300, P2P: 9222/tcp+udp
# Prometheus                  UI: 9090
# Grafana                     UI: 3000

# Host used when connecting from host machine (same as compose port mappings)
COMPOSE_HOST=127.0.0.1

# L1 (mainnet) — reth
L1_RPC_HTTP=http://127.0.0.1:8545
L1_RPC_WS=ws://127.0.0.1:8546
L1_ENGINE_HTTP=http://127.0.0.1:8551
L1_RETH_METRICS=http://127.0.0.1:9001

# L1 Beacon — lighthouse
L1_BEACON_HTTP=http://127.0.0.1:5052
L1_LIGHTHOUSE_METRICS=http://127.0.0.1:8008

# L2 (Base) — base-reth
L2_RPC_HTTP=http://127.0.0.1:8547
L2_RPC_WS=ws://127.0.0.1:8548
L2_ENGINE_HTTP=http://127.0.0.1:8552
L2_BASE_RETH_METRICS=http://127.0.0.1:9002

# Rollup client (op-node)
ROLLUP_RPC_HTTP=http://127.0.0.1:7545
ROLLUP_METRICS=http://127.0.0.1:7300

# Monitoring
PROMETHEUS_URL=http://127.0.0.1:9090
GRAFANA_URL=http://127.0.0.1:3000

# ============================================================
# Database Configuration (Required - src/database/base.rs)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blockchain_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ============================================================
# Chain Selection (used across most binaries)
# ============================================================
# Which chain to target. The code dynamically loads {CHAIN}_ENDPOINT.
# Options: ethereum, base, polygon, arbitrum, optimism, avalanche, polygonzk, zksync, mantle, linea
CHAIN=base

# ============================================================
# Chain RPC Endpoints
# Only the endpoint matching your CHAIN selection is required.
# Matches docker-compose: base-reth HTTP 8547, WS 8548.
# ============================================================
ETHEREUM_ENDPOINT=http://127.0.0.1:8545
POLYGON_ENDPOINT=https://polygon-mainnet.example.com
ARBITRUM_ENDPOINT=https://arbitrum-mainnet.example.com
BASE_ENDPOINT=http://127.0.0.1:8547
OPTIMISM_ENDPOINT=https://optimism-mainnet.example.com
AVALANCHE_ENDPOINT=https://avalanche-mainnet.example.com
POLYGONZK_ENDPOINT=https://polygon-zkevm-mainnet.example.com
ZKSYNC_ENDPOINT=https://zksync-mainnet.example.com
MANTLE_ENDPOINT=https://mantle-mainnet.example.com
LINEA_ENDPOINT=https://linea-mainnet.example.com

# ============================================================
# Live Pipeline Endpoints (Required for live/profiling binaries)
# Used by: run_live, profile_pool_lens, quote_effective_v2, trade_executor
# Matches docker-compose: base-reth 8547 (HTTP), 8548 (WS).
# ============================================================
HTTPS_ENDPOINT=http://127.0.0.1:8547
WS_ENDPOINT=ws://127.0.0.1:8548
# Optional: separate HTTP endpoint for fee queries (falls back to HTTPS_ENDPOINT)
FEE_HTTP_ENDPOINT=http://127.0.0.1:8547

# Optional: used by Python scripts (account_manager.py, operate_v2v3.py)
BASE_RPC_URL=http://127.0.0.1:8547

# ============================================================
# Block Range Configuration (Required for historical sync)
# Used by: unified_discovery, run_historical, run_database
# ============================================================
START_BLOCK=19000000
END_BLOCK=20000000

# ============================================================
# Output & CSV Configuration
# ============================================================
# Directory where CSV files will be saved (Required - src/pipeline/csv.rs)
OUTPUT_DIR=./ETH_DATA/

# Write CSV every N blocks (default: 1) - used by run_historical, pipeline
CSV_WRITE_INTERVAL=1

# ============================================================
# Pool CSV Paths (Required for run_live, optional for run_historical)
# ============================================================
V2_POOLS_CSV=./v2_pools.csv
V3_POOLS_CSV=./v3_pools.csv
V4_POOLS_CSV=./v4_pools.csv

# ============================================================
# Fee Configuration
# ============================================================
# Path to LP fee CSV. If not provided, default fee of 0.3% is used.
# Used by: run_database
LP_FEE_PATH=./base_v2_fees.csv

# Path to fee overrides CSV (Optional - used by pipeline.rs, live_pipeline.rs)
FEE_OVERRIDES_CSV=quoter_fees.csv

# ============================================================
# Pool Filtering (Optional - used by run_historical)
# Set to true/1/yes to disable filtering by the pool CSVs above
# ============================================================
DISABLE_V2_FILTERING=false
DISABLE_V3_FILTERING=false
DISABLE_V4_FILTERING=false

# ============================================================
# Liquidity Thresholds (Optional - used by C++ algo: cpp_algo.cpp, cpp_csv.cpp)
# ============================================================
MIN_POOL_LIQUIDITY_WETH=0.0
MAX_POOL_LIQUIDITY_WETH=50000
MIN_ACTIVE_LIQUIDITY_WETH=0.0
MAX_ACTIVE_LIQUIDITY_WETH=50000

# ============================================================
# Priority Fee Configuration (Optional)
# ============================================================
# Percentile for priority fee selection (default: 70 in C++, 50 in Rust)
# Used by: cpp_algo.cpp, execution.rs
PRIORITY_FEE_PERCENTILE=5
# Profit share percentage for priority fees (default: 0.0)
# Used by: trade_executor.rs
PRIORITY_FEE_PROFIT_SHARE=0.5

# ============================================================
# Redis Configuration (Required for live pipeline)
# Used by: trade_executor, execution, run_live, account_manager.py, operate_v2v3.py
# ============================================================
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_CACHE=redis://127.0.0.1:6380
REDIS_CACHE=redis://127.0.0.1:6380

# Path to Redis setup script (default: ./src/live_pipeline/redis_setup.sh)
REDIS_SETUP_PATH=./src/live_pipeline/redis_setup.sh

# ============================================================
# Contract Addresses (Required for live trading)
# Used by: trade_executor, constants.rs, operate_v2v3.py
# ============================================================
PRODUCTION_CONTRACT_ADDRESS=0x222ab238751b3de524b7738b5ee8cfd307d27208
OPTIMIZER_CONTRACT_ADDRESS=0xd197a6849041de1a5908329bc2eeea1e6f3e92b6
# Quoter contract for fee calculations (Required - validator.rs, querier.rs, run_live)
QUOTER_ADDRESS=0xec27eed5e792ab7ea212ba5541c1c90fffa997e1

# ============================================================
# Wallet / Signing (Required for live trading)
# Used by: quote_effective_v2, account_manager.py, operate_v2v3.py
# ============================================================
PRIVATE_KEY=your_private_key_here
PUBLIC_ADDRESS=your_public_address_here

# ============================================================
# Executable Path (live pipeline)
# ============================================================
EXECUTABLE_PATH=./src/live_pipeline/executable/MCMBF.exe

# ============================================================
# Block Explorer API Keys (Optional)
# Used by: profile_pool_lens, run_live (ETHERSCAN_API_KEY)
# Others may be used for chain-specific lookups
# ============================================================
# ETHERSCAN_API_KEY=your_etherscan_api_key
# POLYGONSCAN_API_KEY=your_polygonscan_api_key
# ARBISCAN_API_KEY=your_arbiscan_api_key
# BASESCAN_API_KEY=your_basescan_api_key
# SNOWSCAN_API_KEY=your_snowscan_api_key
# OPTIMISTIC_ETHERSCAN_API_KEY=your_optimistic_etherscan_api_key
# ZKSYNC_API_KEY=your_zksync_api_key
# MANTLESCAN_API_KEY=your_mantlescan_api_key
# POLYGONZKSCAN_API_KEY=your_polygonzkscan_api_key
# LINEASCAN_API_KEY=your_lineascan_api_key

# ============================================================
# Feature Flags (Optional)
# ============================================================
FLASHBLOCKS_ENABLED=false