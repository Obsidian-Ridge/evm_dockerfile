    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "P2P peer count across L1 (reth, lighthouse), L2 (base-reth), and rollup-client (op-node). Reth exposes reth_network_connected_peers. base-reth uses same metric; 0 peers is normal when base-reth is a replica. If Lighthouse shows no data, its metric name may differ.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "reth_network_connected_peers{job=\"reth\"}", "legendFormat": "L1 reth", "refId": "A" },
        { "expr": "op_node_default_p2p_peer_count{job=\"rollup-client\"}", "legendFormat": "rollup-client (op-node)", "refId": "B" },
        { "expr": "reth_network_connected_peers{job=\"base-reth\"}", "legendFormat": "L2 base-reth", "refId": "C" },
        { "expr": "lighthouse_network_connected_peers{job=\"lighthouse\"}", "legendFormat": "L1 lighthouse", "refId": "D" }
